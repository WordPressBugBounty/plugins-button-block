#: build/admin/dashboard.js:1
msgid "Add the Button Block"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Open the block editor on any post or page. Click the <strong>+</strong> icon in the top-left corner or type <strong>/Button Block</strong> to find and insert the Button Block."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Open Editor"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Customize Style"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Use the block settings in the sidebar to style your button. You can choose layouts, customize alignment, add hover effects, set typography, adjust border-radius, background, and text colors."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Configure Button Action"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Configure what happens when a user clicks the button. Set the link URL, choose whether it opens a popup (Pro), triggers a file download (Pro), or set custom rel attributes and referrer policies."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Style & Publish"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Use the design controls to customize hover states, custom shadows, and animations. When satisfied, publish or update the page."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Open Button Block Generator"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Go to <strong>Button Block &rsaquo; Add New</strong> (or the Button Block CPT list) in your WordPress admin menu to create a reusable button."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Button Block Generator"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Configure the Block"
msgstr ""

#: build/admin/dashboard.js:1
msgid "In the editor, design and customize your button using the block options in the sidebar. Give it a title for easy reference and publish it."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Copy the Shortcode"
msgstr ""

#: build/admin/dashboard.js:1
msgid "After publishing, go to the <strong>Button Block</strong> list table. You will see a <strong>ShortCode</strong> column displaying <code>[btn_block id=POST_ID]</code>. Click it to copy to your clipboard."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Paste Anywhere"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Paste the copied shortcode (e.g. <code>[btn_block id=123]</code>) into any post, page, widget area, or layout using the <strong>Shortcode</strong> block."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Create a Button Post"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Go to <strong>Button Block &rsaquo; Add New</strong>, design your button, and publish it. Copy the shortcode <code>[btn_block id=YOUR_ID]</code> from the list table."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Add Shortcode Widget"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Open the Elementor editor on any page. Search for the <strong>Shortcode</strong> widget and drag it to your desired section/column."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Enter & Preview"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Paste your shortcode (e.g. <code>[btn_block id=123]</code>) into the Shortcode input box to preview the stylized button live on the canvas."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Go to <strong>Button Block &rsaquo; Add New</strong>, customize your button, and copy the shortcode <code>[btn_block id=YOUR_ID]</code> from the post list."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Open Theme File"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Open the PHP template file in your theme where you want the button to appear (e.g. <code>header.php</code>, <code>footer.php</code>, <code>single.php</code>, or custom template files)."
msgstr ""

#: build/admin/dashboard.js:1
msgid "Render via do_shortcode"
msgstr ""

#: build/admin/dashboard.js:1
msgid "Add <code>&lt;?php echo do_shortcode('[btn_block id=YOUR_ID]'); ?&gt;</code> (replace <em>YOUR_ID</em> with the actual post ID) to render the button."
msgstr ""

